    {
      "type": "text", "id": "multihead_desc",
      "x": 720, "y": 755, "width": 380, "height": 100,
      "text": "Each head learns different relationships:\n  Head 1: syntactic (subject-verb)\n  Head 2: semantic (adjective-noun)\n  Head 3: positional (nearby tokens)\n  ...\n\nConcat(head_1,...,head_h) × W_O → output",
      "originalText": "Each head learns different relationships:\n  Head 1: syntactic (subject-verb)\n  Head 2: semantic (adjective-noun)\n  Head 3: positional (nearby tokens)\n  ...\n\nConcat(head_1,...,head_h) × W_O → output",
      "fontSize": 13, "fontFamily": 3, "textAlign": "left", "verticalAlign": "top",
      "strokeColor": "#64748b", "backgroundColor": "transparent",
      "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid",
      "roughness": 0, "opacity": 100, "angle": 0,
