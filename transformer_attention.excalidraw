    {
      "type": "text", "id": "evidence_text",
      "x": 725, "y": 355, "width": 280, "height": 165,
      "text": "\"The cat sat on\"\n\n      The  cat  sat  on\nThe  [.10  .70  .10  .10]\ncat  [.20  .30  .40  .10]\nsat  [.10  .50  .20  .20]\non   [.30  .10  .20  .40]\n\nEach row sums to 1.0\nHigh value = strong attention",
      "originalText": "\"The cat sat on\"\n\n      The  cat  sat  on\nThe  [.10  .70  .10  .10]\ncat  [.20  .30  .40  .10]\nsat  [.10  .50  .20  .20]\non   [.30  .10  .20  .40]\n\nEach row sums to 1.0\nHigh value = strong attention",
      "fontSize": 13, "fontFamily": 3, "textAlign": "left", "verticalAlign": "middle",
      "strokeColor": "#22c55e", "backgroundColor": "transparent",
      "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid",
      "roughness": 0, "opacity": 100, "angle": 0,
      "seed": 300032, "version": 1, "versionNonce": 300033,
      "isDeleted": false, "groupIds": [], "boundElements": null,
      "link": null, "locked": false, "containerId": "evidence_rect", "lineHeight": 1.25
    },

