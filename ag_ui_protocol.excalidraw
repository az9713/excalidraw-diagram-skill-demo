      "type": "text", "id": "code_text",
      "x": 565, "y": 535, "width": 480, "height": 120,
      "text": "import { HttpAgent } from '@ag-ui/client';\n\nconst agent = new HttpAgent({ url: \"/agent\" });\n\nagent.run(input).subscribe({\n  next: (event) => {\n    if (event.type === 'TEXT_MESSAGE_CONTENT')\n      appendToChat(event.delta);\n  }\n});",
      "originalText": "import { HttpAgent } from '@ag-ui/client';\n\nconst agent = new HttpAgent({ url: \"/agent\" });\n\nagent.run(input).subscribe({\n  next: (event) => {\n    if (event.type === 'TEXT_MESSAGE_CONTENT')\n      appendToChat(event.delta);\n  }\n});",
